# PlatformIO
.pio/
.pioenvs/
.piolibdeps/
*.pyc
__pycache__/

# Build artifacts — release .bin/.uf2 are published by CI to Pages, not committed
*.bin
*.elf
*.map
*.o
*.a
!web/firmware/**        # except merged flasher binaries staged for Pages, if any

# Simulator build output
sim/build/
*.exe

# Editor / OS junk
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.swp

# Local secrets / device-specific
*.local
secrets.h

# Full-flash factory images dumped from bench boards (16 MB binaries, local
# only — covered by *.bin above, listed explicitly for clarity). Restore with:
#   python -m esptool --port COMx --baud 921600 write_flash 0x0 \
#     hardware/factory_backups/<image>.bin
hardware/factory_backups/
